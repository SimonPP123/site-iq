# ============================================================
# Site IQ - environment variables. Copy to .env.local and fill.
# .env.local is gitignored - NEVER commit real values.
# ============================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only (privileged server routes / scripts). NEVER expose to the browser.
# Also used by the Postgres-backed rate limiter (check_rate_limit RPC) and account-deletion.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- n8n (monkata) webhook endpoints (filled after deploying the workflows) ---
N8N_AUDIT_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/site-audit
N8N_CHAT_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/site-chat
# Contact + transactional email both route through n8n (-> Gmail) when set.
N8N_CONTACT_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/site-contact

# --- App -> n8n webhook auth ---
# Shared secret sent as the X-SIS-Secret header on the trigger call (over TLS); n8n verifies it.
# Generate with: openssl rand -hex 32
SIS_WEBHOOK_SECRET=your-header-auth-secret
# Trust model: n8n writes audit results straight back to Supabase using its OWN service-role
# credential, gated by RLS - there is no inbound webhook into this app, so no body-signing
# (HMAC) secret is needed here. The trigger above is the only app -> n8n call.

# --- Operational kill-switches + cost ceiling ---
# Set to "false" to instantly disable an expensive path WITHOUT a redeploy (maintenance / incident).
AUDITS_ENABLED=true
CHAT_ENABLED=true
# Global daily circuit-breaker: hard ceiling on total audits/day across ALL users (cost protection).
# Leave unset for no global cap. Recommended for public launch (e.g. a few hundred).
# GLOBAL_DAILY_AUDIT_CAP=300

# --- Anti-abuse ---
# Rate-limiting is Postgres-backed (no Upstash). No captcha by design - the app-layer limits + the
# Postgres per-user/per-IP buckets + the global daily cap are the abuse controls.

# --- Email ---
# Transactional + contact notifications primarily route through n8n + Gmail (above). Resend is an
# optional fallback / direct sender. CONTACT_EMAIL is where contact-form leads are emailed.
# CONTACT_EMAIL=you@example.com
# RESEND_API_KEY=re_your-api-key
# EMAIL_FROM=Site IQ <noreply@yourdomain.com>

# --- Sentry error tracking (optional) ---
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project

# --- Admin (optional) ---
# Comma-separated allowlist of admin emails. Empty/unset = no admins.
# ADMIN_EMAILS=you@example.com

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
